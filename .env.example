# ─────────────────────────────────────────────────────────────────────────────
# DataQuest AI v3.0 — Variables d'environnement requises
# Copier ce fichier en .env et remplir TOUTES les valeurs obligatoires.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données (OBLIGATOIRE) ─────────────────────────────────────────────
POSTGRES_USER=dataquest
POSTGRES_PASSWORD=<mot-de-passe-fort-à-changer>
DATABASE_URL=postgresql://dataquest:<mot-de-passe-fort-à-changer>@localhost:5432/dataquest

# ── JWT (OBLIGATOIRE — minimum 64 caractères aléatoires) ─────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=<générer-avec-openssl-rand-base64-64-MINIMUM-64-CARACTERES>

# ── IA — Au moins l'une des deux sources ─────────────────────────────────────
# Option A : Anthropic Claude (recommandé en production)
ANTHROPIC_API_KEY=sk-ant-...

# Option B : Ollama local (dev — installer: https://ollama.com, puis: ollama pull qwen2.5:7b)
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── Redis (OBLIGATOIRE pour docker-compose) ───────────────────────────────────
REDIS_PASSWORD=<mot-de-passe-redis-fort>

# ── URLs (OBLIGATOIRE pour docker-compose) ────────────────────────────────────
FRONTEND_URL=http://localhost:80
BACKEND_URL=http://localhost:3001

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (dev local) ──────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
