generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  level        Int      @default(1)
  xp           Int      @default(0)
  dataCoins    Int      @default(0)
  streak       Int      @default(0)
  eloRating    Int      @default(1000)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  progress     ConceptProgress[]
  sm2Cards     SM2Card[]
  badges       UserBadge[]
  sessions     LearningSession[]
  battles      Battle[]          @relation("BattleParticipant")
  certificates Certificate[]
}

model ConceptProgress {
  id          String    @id @default(uuid())
  userId      String
  conceptId   String
  phase1Done  Boolean   @default(false)
  phase2Done  Boolean   @default(false)
  phase3Done  Boolean   @default(false)
  phase4Done  Boolean   @default(false)
  phase5Done  Boolean   @default(false)
  phase6Done  Boolean   @default(false)
  isValidated Boolean   @default(false)
  xpEarned    Int       @default(0)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id])
  @@unique([userId, conceptId])
}

model SM2Card {
  id               String   @id @default(uuid())
  userId           String
  conceptId        String
  repetitionNumber Int      @default(0)
  easinessFactor   Float    @default(2.5)
  interval         Int      @default(1)
  nextReviewDate   DateTime @default(now())
  lastReviewDate   DateTime @default(now())
  qualityHistory   Int[]
  decayLevel       Float    @default(0.0)

  user User @relation(fields: [userId], references: [id])
  @@unique([userId, conceptId])
}

model LearningSession {
  id             String    @id @default(uuid())
  userId         String
  conceptId      String
  phase          Int
  questionsAsked Int       @default(0)
  correctAnswers Int       @default(0)
  livesRemaining Int       @default(3)
  errorTypes     Json      @default("{}")
  xpEarned       Int       @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Battle {
  id           String    @id @default(uuid())
  conceptId    String
  player1Id    String
  player2Id    String
  winnerId     String?
  player1Score Int       @default(0)
  player2Score Int       @default(0)
  status       String    @default("pending")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  player1 User @relation("BattleParticipant", fields: [player1Id], references: [id])
}

model Certificate {
  id        String   @id @default(uuid())
  userId    String
  blockId   Int
  blockName String
  xpAtTime  Int
  accuracy  Float
  issuedAt  DateTime @default(now())
  publicUrl String   @unique

  user User @relation(fields: [userId], references: [id])
}

model Badge {
  id          String @id
  name        String
  description String
  icon        String
  category    String
  xpReward    Int

  users UserBadge[]
}

model UserBadge {
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])
  @@id([userId, badgeId])
}
